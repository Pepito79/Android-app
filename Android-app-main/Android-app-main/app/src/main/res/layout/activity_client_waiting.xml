<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:padding="24dp">

    <TextView
        android:id="@+id/titleClient"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:text="La Maison Bluetooth"
        android:textColor="#008577"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnStatusClient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:backgroundTint="#D3D3D3"
        android:clickable="false"
        android:text="CLIENT EN ATTENTE"
        android:textColor="#333333" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnStatusClient"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:text="*Attente de connection au serveur*"
        android:textColor="#888888"
        android:textStyle="italic" />

    <ProgressBar
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="50dp"
        android:indeterminateTint="#008577" />

</RelativeLayout>