<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Passerelle Domotique (Serveur)"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"/>

    <View
        android:id="@+id/status_indicator"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_below="@id/title_text"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="50dp"
        android:background="@android:drawable/stat_sys_data_bluetooth"
        android:backgroundTint="#008577" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/status_indicator"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:text="Initialisation du Bluetooth..."
        android:textSize="18sp"
        android:textColor="#666666" />

    <TextView
        android:id="@+id/info_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/status_text"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Ce téléphone doit rester à portée Bluetooth du client et connecté au Wi-Fi."
        android:textSize="14sp"
        android:fontFamily="sans-serif-light"
        android:textColor="#999999" />

    <Button
        android:id="@+id/btn_stop_server"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="30dp"
        android:text="Arrêter le serveur"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF" />

</RelativeLayout>